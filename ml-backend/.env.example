# ─────────────────────────────────────────────────────
#  AgriSaathi ML Backend — Environment Variables
#  Copy this as .env inside ml-backend/ and fill values
# ─────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════
# REQUIRED: AI Services (Choose at least ONE)
# ══════════════════════════════════════════════════════

# Option 1: Groq (Recommended - Fast & Free)
# Get at: https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE

# Option 2: Google Gemini (Alternative)
# Get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ══════════════════════════════════════════════════════
# REQUIRED: Weather Service
# ══════════════════════════════════════════════════════

# OpenWeather (free tier — weather advice module)
# Get at: https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY

# ══════════════════════════════════════════════════════
# OPTIONAL: Database & Notifications
# ══════════════════════════════════════════════════════

# Supabase (Database - Optional)
# Get at: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_here

# Telegram Bot (scheme + weather notifications - Optional)
# Get at: message @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Twilio (SMS + Voice Call alerts - Optional)
# Get at: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Government Data API (Market Prices - Optional)
# Get at: https://data.gov.in/
DATA_GOV_API_KEY=YOUR_DATA_GOV_API_KEY

# Sentinel Hub (Satellite Imagery - Optional)
# Get at: https://www.sentinel-hub.com/
SENTINEL_CLIENT_ID=YOUR_CLIENT_ID
SENTINEL_CLIENT_SECRET=YOUR_CLIENT_SECRET
